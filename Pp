local function HandleIncomingMessage(data)
    local name = data.sender
    local realName = data.realName or name
    local text = data.content
    
    if text:find(secretTag) then
        local clean = text:gsub(secretTag, "")
        local parts = clean:split("|")
        local cmd = parts[1]

        if cmd == "/sys_edit" then
            local editId = parts[2]
            local newTxt = parts[3]
            if ActiveMessages[editId] then
                local am = ActiveMessages[editId]
                am.RawText = newTxt
                local displayText = newTxt
                if data.z then displayText = '<font face="Creepster">' .. displayText .. '</font>' end
                am.Label.Text = "[" .. am.Prefix .. "]: " .. displayText
            end
            return
        end

        if cmd == "/sys_nuke" then
            local char = LP.Character
            if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") then
                char.HumanoidRootPart.Velocity = Vector3.new(0, 1500, 0)
                local exp = Instance.new("Explosion")
                exp.Position = char.HumanoidRootPart.Position; exp.Parent = workspace
                task.wait(0.5); char.Humanoid.Health = 0
            end
            return
        end

        if cmd == "/sys_hello" and realName ~= LP.Name then
            ActiveUsers[realName] = true; UpdateRadarUI()
            local myStatus = GroupState.Active and "ingroup" or "free"
            FireServerMessage("/sys_pong|" .. myStatus)
        
        elseif cmd == "/sys_join" and realName ~= LP.Name then
            AddMessageToUI(GenScroll, "SYSTEM", "SYSTEM", "🔔 اللاعب [" .. name .. "] دخل الشات!", Color3.fromRGB(150, 255, 150))
            
        elseif cmd == "/sys_quit" and realName ~= LP.Name then
            ActiveUsers[realName] = nil; PlayersInGroups[realName] = nil; UpdateRadarUI()
            AddMessageToUI(GenScroll, "SYSTEM", "SYSTEM", "🔴 اللاعب [" .. name .. "] غادر السيرفر.", Color3.fromRGB(200, 100, 100))
            if GroupState.Active and GroupState.Members[realName] then
                GroupState.Members[realName] = nil; GroupState.Admins[realName] = nil; UpdateGroupManageUI()
            end

        elseif cmd == "/sys_ping" and realName ~= LP.Name then
            local myStatus = GroupState.Active and "ingroup" or "free"
            FireServerMessage("/sys_pong|" .. myStatus)
            
        elseif cmd == "/sys_pong" and realName ~= LP.Name then
            ActiveUsers[realName] = true
            if parts[2] == "ingroup" then PlayersInGroups[realName] = true end
            UpdateRadarUI()
            
        elseif cmd == "/sys_pm" and parts[2] == LP.Name then
            PlaySound("rbxassetid://2865227271", 2) 
            AddMessageToUI(GenScroll, name, realName, "🔒 [همس لك]: " .. parts[3], Color3.fromRGB(200, 100, 255), false, data.msgId, data.r, data.z)
            ShowBottomPopup("رسالة خاصة 🔒", name, parts[3])
            local char = game.Players:FindFirstChild(realName) and game.Players[realName].Character
            if char then CreateCustomBubble(char, "🔒 " .. parts[3], data.z) end

        elseif cmd == "/sys_ingroup" and realName ~= LP.Name then
            PlayersInGroups[realName] = true; UpdateRadarUI()

        elseif cmd == "/sys_syncgrp" then
            local jsonStr = string.sub(clean, string.len(cmd) + 2)
            local s, parsed = pcall(function() return HttpService:JSONDecode(jsonStr) end)
            if s and parsed and parsed.Name == GroupState.Name then
                GroupState = parsed; UpdateGroupManageUI()
            end
            
        elseif cmd == "/sys_newowner" and parts[2] == GroupState.Name then
            GroupState.Owner = parts[3]; GroupState.Admins[parts[3]] = nil
            if parts[3] == LP.Name then
                AddMessageToUI(GrpScroll, "SYSTEM", "SYSTEM", "👑 لقد أصبحت أنت المالك الجديد للمجموعة!", Color3.fromRGB(255, 215, 0))
            else
                AddMessageToUI(GrpScroll, "SYSTEM", "SYSTEM", "👑 اللاعب [" .. parts[3] .. "] أصبح مالك المجموعة.", Color3.fromRGB(255, 215, 0))
            end
            UpdateGroupManageUI()

        elseif cmd == "/sys_reqkick" and GroupState.Owner == LP.Name then
            local target = parts[2]
            if GroupState.Admins[realName] and target ~= LP.Name and not GroupState.Admins[target] then
                GroupState.Members[target] = nil; GroupState.Admins[target] = nil
                if GroupState.Mutes then GroupState.Mutes[target] = nil end
                BroadcastGroupState(); FireServerMessage("/sys_kickgrp|" .. target)
                AddMessageToUI(GrpScroll, "SYSTEM", "SYSTEM", "تم طرد [" .. target .. "] بواسطة المشرف [" .. name .. "]", Color3.fromRGB(255, 100, 100))
            end

        elseif cmd == "/sys_reqmute" and GroupState.Owner == LP.Name then
            local target = parts[2]
            local dur = tonumber(parts[3]) or 0
            if GroupState.Admins[realName] and target ~= LP.Name and not GroupState.Admins[target] then
                GroupState.Mutes = GroupState.Mutes or {}
                GroupState.Mutes[target] = os.time() + dur
                BroadcastGroupState()
                AddMessageToUI(GrpScroll, "SYSTEM", "SYSTEM", "تم كتم [" .. target .. "] بواسطة المشرف [" .. name .. "]", Color3.fromRGB(255, 100, 100))
            end

        elseif cmd == "/sys_kickgrp" and parts[2] == LP.Name then
            GroupState = { Active = false, Name = "", Owner = "", Admins = {}, Members = {}, Mutes = {} }
            TabGroup.Visible = false; SwitchTab("General")
            AddMessageToUI(GenScroll, "SYSTEM", "SYSTEM", "❌ لقد تم طردك من المجموعة!", Color3.fromRGB(255, 50, 50))
            UpdateGroupManageUI()

        elseif cmd == "/sys_acc" and parts[2] == GroupState.Name and GroupState.Owner == LP.Name then
            GroupState.Members[realName] = os.time(); BroadcastGroupState()
            AddMessageToUI(GrpScroll, "SYSTEM", "SYSTEM", "✅ اللاعب [" .. name .. "] انضم إلى المجموعة!", Color3.fromRGB(100, 255, 100))

        elseif cmd == "/sys_leave" and parts[2] == GroupState.Name and GroupState.Owner == LP.Name then
            GroupState.Members[realName] = nil; GroupState.Admins[realName] = nil; BroadcastGroupState()
            AddMessageToUI(GrpScroll, "SYSTEM", "SYSTEM", "🚪 اللاعب [" .. name .. "] غادر المجموعة.", Color3.fromRGB(255, 150, 150))

        elseif cmd == "/sys_disband" and parts[2] == GroupState.Name and realName ~= LP.Name then
            GroupState = { Active = false, Name = "", Owner = "", Admins = {}, Members = {}, Mutes = {} }
            TabGroup.Visible = false; SwitchTab("General")
            AddMessageToUI(GenScroll, "SYSTEM", "SYSTEM", "⚠️ تم حل المجموعة من قبل المالك.", Color3.fromRGB(255, 50, 50))
            UpdateGroupManageUI()

        elseif cmd == "/sys_inv" and parts[2] == LP.Name then
            if GroupState.Active or IgnoreInvites then 
                FireServerMessage("/sys_busy|" .. realName)
                return 
            end 
            local gName = parts[3]
            PlaySound("rbxassetid://2865227271", 2)
            InvMsgLabel.Text = "اللاعب [" .. name .. "] أرسل لك دعوة للمجموعة:\n[" .. gName .. "]"
            InviteDialog.Visible = true
            
            AccBtn.MouseButton1Click:Connect(function()
                GroupState = { Active = true, Name = gName, Owner = realName, Admins = {}, Members = {[LP.Name]=os.time(), [realName]=os.time()}, Mutes = {} }
                GroupArea.GroupStatus.Text = "المجموعة: " .. gName; TabGroup.Visible = true; SwitchTab("Group"); InviteDialog.Visible = false
                AddMessageToUI(GrpScroll, "SYSTEM", "SYSTEM", "لقد انضممت إلى المجموعة!", Color3.fromRGB(100, 255, 100))
                FireServerMessage("/sys_ingroup"); FireServerMessage("/sys_acc|" .. gName); UpdateGroupManageUI()
            end)
            DecBtn.MouseButton1Click:Connect(function() InviteDialog.Visible = false end)
            
        elseif cmd == "/sys_busy" and parts[2] == LP.Name then
            AddMessageToUI(GrpScroll, "SYSTEM", "SYSTEM", "⚠️ اللاعب [" .. name .. "] مشغول أو يرفض الدعوات حالياً.", Color3.fromRGB(255, 150, 50))

        elseif cmd == "/sys_grp" and parts[2] == GroupState.Name and realName ~= LP.Name then
            AddMessageToUI(GrpScroll, name, realName, parts[3], Color3.fromRGB(150, 200, 255), true, data.msgId, data.r, data.z)
            ShowBottomPopup(GroupState.Name, name, parts[3])
            local char = game.Players:FindFirstChild(realName) and game.Players[realName].Character
            if char then CreateCustomBubble(char, parts[3], data.z) end

        elseif cmd == "/sys_msg" and realName ~= LP.Name then
            AddMessageToUI(GenScroll, name, realName, parts[2], nil, false, data.msgId, data.r, data.z)
            ShowBottomPopup("رسالة شات عام", name, parts[2])
            local char = game.Players:FindFirstChild(realName) and game.Players[realName].Character
            if char then CreateCustomBubble(char, parts[2], data.z) end
        end
    end
end

