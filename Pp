local function GetRainbowText(txt)
    local colors = {"#FF0000", "#FF7F00", "#FFFF00", "#00FF00", "#0000FF", "#4B0082", "#9400D3"}
    local res = ""
    for i = 1, #txt do
        res = res .. '<font color="' .. colors[((i-1) % #colors) + 1] .. '">' .. txt:sub(i, i) .. '</font>'
    end
    return res
end

