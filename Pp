    Instance.new("UIPadding", Input).PaddingLeft = UDim.new(0, 10); Instance.new("UICorner", Input)

    local Btn = Instance.new("TextButton", parentArea)
    Btn.Size = UDim2.new(0, 70, 0, 35); Btn.Position = UDim2.new(1, -80, 1, -40); Btn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
