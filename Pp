local function SetupChatArea(parentArea, isGroup)
    if isGroup then
        local GLabel = Instance.new("TextLabel", parentArea)
        GLabel.Size = UDim2.new(1, 0, 0, 25); GLabel.BackgroundTransparency = 1; GLabel.Text = "أنت لست في مجموعة حالياً"
        GLabel.TextColor3 = Color3.fromRGB(150, 150, 150); GLabel.Font = SafeFont; GLabel.TextSize = 14; GLabel.Name = "GroupStatus"
    end
    local Scroll = Instance.new("ScrollingFrame", parentArea)
    Scroll.Size = UDim2.new(1, -20, 1, isGroup and -75 or -50); Scroll.Position = UDim2.new(0, 10, 0, isGroup and 25 or 5)
    Scroll.BackgroundTransparency = 1; Scroll.ScrollBarThickness = 3; Scroll.ScrollBarImageColor3 = Color3.fromRGB(200, 0, 0); Scroll.Name = "ChatScroll"
    local Layout = Instance.new("UIListLayout", Scroll); Layout.Padding = UDim.new(0, 5)
    Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() Scroll.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 10) end)

    local Input = Instance.new("TextBox", parentArea)
    Input.Size = UDim2.new(1, -90, 0, 35); Input.Position = UDim2.new(0, 10, 1, -40); Input.BackgroundColor3 = Color3.fromRGB(30, 0, 0)
    Input.TextColor3 = Color3.new(1, 1, 1); Input.Text = ""; Input.PlaceholderText = isGroup and "رسالة للمجموعة..." or "رسالة للعام..."
