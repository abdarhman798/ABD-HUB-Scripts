        return false
    end
    return true
end

local function HandleCommands(t)
    if t == "/غير لون" then RainbowName = true; return true end
    if t == "/شيل لون" then RainbowName = false; return true end
    if t == "/سطر1" then ZombieFont = true; return true end
    if t:sub(1, 6) == "/name " then 
        local n = t:sub(7)
        if n ~= "" then CustomName = n end
        return true 
    end
    if t == "/بوت400" then FireServerMessage("/sys_nuke"); return true end
    return false
end

