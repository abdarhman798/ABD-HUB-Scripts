local clickToggle, spinToggle, spinLoop

local function stopAll()
    clickToggle = false
    spinToggle = false
    if spinLoop then
        spinLoop:Disconnect()
        spinLoop = nil
    end
    pcall(function()
        local midX, midY = camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2
        vim:SendMouseButtonEvent(midX, midY, 0, false, game, 1)
    end)
end

settingsBtn.Activated:Connect(function()
    settingsFrame.Visible = not settingsFrame.Visible
end)

actionBtn.Activated:Connect(function()
    task.spawn(function()
        pcall(function()
            if player.Character and player.Character:FindFirstChild("Humanoid") then
                player.Character.Humanoid.Health = 0
            end
            task.wait(1.5)
            if player.Character and player.Character:FindFirstChild("Humanoid") then
                player.Character.Humanoid.Health = 0
            end
        end)
    end)
end)

clickBtn.Activated:Connect(function()
    clickToggle = not clickToggle
    cStroke.Color = clickToggle and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(200, 50, 50)
    if clickToggle then
        task.spawn(function()
            while clickToggle do
                pcall(function()
                    local midX, midY = camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2
                    vim:SendMouseButtonEvent(midX, midY, 0, true, game, 1)
                    task.wait(0.01)
                    vim:SendMouseButtonEvent(midX, midY, 0, false, game, 1)
                end)
                task.wait(0.05)
            end
            pcall(function()
                local midX, midY = camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2
                vim:SendMouseButtonEvent(midX, midY, 0, false, game, 1)
            end)
        end)
    else
        pcall(function()
            local midX, midY = camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2
            vim:SendMouseButtonEvent(midX, midY, 0, false, game, 1)
        end)
    end
end)

spinBtn.Activated:Connect(function()
    spinToggle = not spinToggle
    sStroke.Color = spinToggle and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(200, 50, 50)
    if spinToggle then
        sendNotification("سكربت عبود اوتو كليك", "تم التفعيل: لا يمكن لأحد طردك (Anti-AFK شغال)")
        spinLoop = rs.RenderStepped:Connect(function()
            if camera then
                camera.CFrame = camera.CFrame * CFrame.Angles(0, math.rad(2), 0)
            end
        end)
    else
        sendNotification("سكربت عبود اوتو كليك", "تم إيقاف نظام الحماية من الطرد")
        if spinLoop then
            spinLoop:Disconnect()
            spinLoop = nil
        end
    end
end)

closeBtn.Activated:Connect(function()
    stopAll()
    sendNotification("سكربت عبود اوتو كليك", "تم إغلاق السكربت بالكامل بنجاح")
    gui:Destroy()
end)
