local function HandleIncomingMessage(name, text)
    if text:find(secretTag) then
        local clean = text:gsub(secretTag, "")
        local parts = clean:split("|")
        local cmd = parts[1]

        if cmd == "/sys_hello" and name ~= LP.Name then
            ActiveUsers[name] = true; UpdateRadarUI()
            local myStatus = GroupState.Active and "ingroup" or "free"
            FireServerMessage("/sys_pong|" .. myStatus)
        
        elseif cmd == "/sys_join" and name ~= LP.Name then
            AddMessageToUI(GenScroll, "SYSTEM", "🔔 اللاعب [" .. name .. "] دخل الشات!", Color3.fromRGB(150, 255, 150))
            
        elseif cmd == "/sys_ping" and name ~= LP.Name then
            local myStatus = GroupState.Active and "ingroup" or "free"
            FireServerMessage("/sys_pong|" .. myStatus)
            
        elseif cmd == "/sys_pong" and name ~= LP.Name then
            ActiveUsers[name] = true
            if parts[2] == "ingroup" then PlayersInGroups[name] = true end
            UpdateRadarUI()
            
        elseif cmd == "/sys_pm" and parts[2] == LP.Name then
            PlaySound("rbxassetid://2865227271", 2) 
            AddMessageToUI(GenScroll, name, "🔒 [همس لك]: " .. parts[3], Color3.fromRGB(200, 100, 255))
            local char = game.Players:FindFirstChild(name) and game.Players[name].Character
            if char then CreateCustomBubble(char, "🔒 " .. parts[3]) end

        elseif cmd == "/sys_ingroup" and name ~= LP.Name then
            PlayersInGroups[name] = true; UpdateRadarUI()

        elseif cmd == "/sys_syncgrp" then
            local jsonStr = string.sub(clean, string.len(cmd) + 2)
            local s, parsed = pcall(function() return HttpService:JSONDecode(jsonStr) end)
            if s and parsed and parsed.Name == GroupState.Name then
                GroupState = parsed; UpdateGroupManageUI()
            end
            
        elseif cmd == "/sys_reqkick" and GroupState.Owner == LP.Name then
            local target = parts[2]
            if GroupState.Admins[name] and target ~= LP.Name and not GroupState.Admins[target] then
                GroupState.Members[target] = nil; GroupState.Admins[target] = nil
                if GroupState.Mutes then GroupState.Mutes[target] = nil end
                BroadcastGroupState()
                FireServerMessage("/sys_kickgrp|" .. target)
                AddMessageToUI(GrpScroll, "SYSTEM", "تم طرد [" .. target .. "] بواسطة المشرف [" .. name .. "]", Color3.fromRGB(255, 100, 100))
            end

        elseif cmd == "/sys_reqmute" and GroupState.Owner == LP.Name then
            local target = parts[2]
            local dur = tonumber(parts[3]) or 0
            if GroupState.Admins[name] and target ~= LP.Name and not GroupState.Admins[target] then
                GroupState.Mutes = GroupState.Mutes or {}
                GroupState.Mutes[target] = os.time() + dur
                BroadcastGroupState()
                AddMessageToUI(GrpScroll, "SYSTEM", "تم كتم [" .. target .. "] بواسطة المشرف [" .. name .. "]", Color3.fromRGB(255, 100, 100))
            end

        elseif cmd == "/sys_kickgrp" and parts[2] == LP.Name then
            GroupState = { Active = false, Name = "", Owner = "", Admins = {}, Members = {}, Mutes = {} }
            TabGroup.Visible = false; SwitchTab("General")
            AddMessageToUI(GenScroll, "SYSTEM", "❌ لقد تم طردك من المجموعة!", Color3.fromRGB(255, 50, 50))
            UpdateGroupManageUI()

        elseif cmd == "/sys_acc" and parts[2] == GroupState.Name and GroupState.Owner == LP.Name then
            GroupState.Members[name] = true; BroadcastGroupState()
            AddMessageToUI(GrpScroll, "SYSTEM", "✅ اللاعب [" .. name .. "] انضم إلى المجموعة!", Color3.fromRGB(100, 255, 100))

        elseif cmd == "/sys_leave" and parts[2] == GroupState.Name and GroupState.Owner == LP.Name then
            GroupState.Members[name] = nil; GroupState.Admins[name] = nil; BroadcastGroupState()
            AddMessageToUI(GrpScroll, "SYSTEM", "🚪 اللاعب [" .. name .. "] غادر المجموعة.", Color3.fromRGB(255, 150, 150))

        elseif cmd == "/sys_disband" and parts[2] == GroupState.Name and name ~= LP.Name then
            GroupState = { Active = false, Name = "", Owner = "", Admins = {}, Members = {}, Mutes = {} }
            TabGroup.Visible = false; SwitchTab("General")
            AddMessageToUI(GenScroll, "SYSTEM", "⚠️ تم حل المجموعة من قبل المالك.", Color3.fromRGB(255, 50, 50))
            UpdateGroupManageUI()

        elseif cmd == "/sys_inv" and parts[2] == LP.Name then
            if GroupState.Active then return end 
            local gName = parts[3]
            PlaySound("rbxassetid://2865227271", 2)
            InvMsgLabel.Text = "اللاعب [" .. name .. "] أرسل لك دعوة للانضمام إلى مجموعة:\n[" .. gName .. "]"
            InviteDialog.Visible = true
            
            AccBtn.MouseButton1Click:Connect(function()
                GroupState = { Active = true, Name = gName, Owner = name, Admins = {}, Members = {[LP.Name]=true, [name]=true}, Mutes = {} }
                GroupArea.GroupStatus.Text = "المجموعة: " .. gName
                TabGroup.Visible = true 
                SwitchTab("Group"); InviteDialog.Visible = false
                AddMessageToUI(GrpScroll, "SYSTEM", "لقد انضممت إلى المجموعة!", Color3.fromRGB(100, 255, 100))
                FireServerMessage("/sys_ingroup") 
                FireServerMessage("/sys_acc|" .. gName); UpdateGroupManageUI()
            end)
            DecBtn.MouseButton1Click:Connect(function() InviteDialog.Visible = false end)

        elseif cmd == "/sys_grp" and parts[2] == GroupState.Name and name ~= LP.Name then
            AddMessageToUI(GrpScroll, name, parts[3], Color3.fromRGB(150, 200, 255), true)
            local char = game.Players:FindFirstChild(name) and game.Players[name].Character
            if char then CreateCustomBubble(char, parts[3]) end

        elseif cmd == "/sys_msg" and name ~= LP.Name then
            AddMessageToUI(GenScroll, name, parts[2])
            local char = game.Players:FindFirstChild(name) and game.Players[name].Character
            if char then CreateCustomBubble(char, parts[2]) end
        end
    end
end

