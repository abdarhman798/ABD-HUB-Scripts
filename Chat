local function ApplyMute(dur)
    if TargetActionPlayer ~= "" then
        if GroupState.Owner == LP.Name then
            GroupState.Mutes = GroupState.Mutes or {}
            GroupState.Mutes[TargetActionPlayer] = os.time() + dur
            BroadcastGroupState()
        elseif GroupState.Admins[LP.Name] then
            FireServerMessage("/sys_reqmute|" .. TargetActionPlayer .. "|" .. dur)
        end
        MuteMenu.Visible = false
    end
end

