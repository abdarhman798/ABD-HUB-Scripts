local function HandleIncomingMessage(name, text)
    if text:find(secretTag) then
        local clean = text:gsub(secretTag, "")
        local parts = clean:split("|")
        local cmd = parts[1]

        if cmd == "/sys_hello" and name ~= LP.Name then
            ActiveUsers[name] = true
            UpdateRadarUI()
            local myStatus = CurrentGroup and "ingroup" or "free"
            FireServerMessage("/sys_pong|" .. myStatus)
        
        elseif cmd == "/sys_join" and name ~= LP.Name then
            AddMessageToUI(GenScroll, "SYSTEM", "🔔 اللاعب [" .. name .. "] دخل الشات!", Color3.fromRGB(150, 255, 150))
            
        elseif cmd == "/sys_ping" and name ~= LP.Name then
            local myStatus = CurrentGroup and "ingroup" or "free"
            FireServerMessage("/sys_pong|" .. myStatus)
            
        elseif cmd == "/sys_pong" and name ~= LP.Name then
            ActiveUsers[name] = true
            if parts[2] == "ingroup" then
                PlayersInGroups[name] = true
            end
            UpdateRadarUI()
            
        elseif cmd == "/sys_pm" and parts[2] == LP.Name then
            PlaySound("rbxassetid://2865227271", 2) 
            AddMessageToUI(GenScroll, name, "🔒 [همس لك]: " .. parts[3], Color3.fromRGB(200, 100, 255))
            local char = game.Players:FindFirstChild(name) and game.Players[name].Character
            if char then CreateCustomBubble(char, "🔒 " .. parts[3]) end

        elseif cmd == "/sys_ingroup" and name ~= LP.Name then
            PlayersInGroups[name] = true
            UpdateRadarUI()
            
        elseif cmd == "/sys_acc" and parts[2] == CurrentGroup and name ~= LP.Name then
            AddMessageToUI(GrpScroll, "SYSTEM", "✅ اللاعب [" .. name .. "] انضم إلى المجموعة!", Color3.fromRGB(100, 255, 100))

        elseif cmd == "/sys_inv" and parts[2] == LP.Name then
            if CurrentGroup then return end 
            local gName = parts[3]
            PlaySound("rbxassetid://2865227271", 2)
            InvMsgLabel.Text = "اللاعب [" .. name .. "] أرسل لك دعوة للانضمام إلى مجموعة:\n[" .. gName .. "]"
            InviteDialog.Visible = true
            
            AccBtn.MouseButton1Click:Connect(function()
                CurrentGroup = gName; GroupArea.GroupStatus.Text = "المجموعة: " .. gName
                TabGroup.Visible = true 
                SwitchTab("Group"); InviteDialog.Visible = false
                AddMessageToUI(GrpScroll, "SYSTEM", "لقد انضممت إلى المجموعة!", Color3.fromRGB(100, 255, 100))
                FireServerMessage("/sys_ingroup") 
                FireServerMessage("/sys_acc|" .. gName) 
            end)
            DecBtn.MouseButton1Click:Connect(function() InviteDialog.Visible = false end)

        elseif cmd == "/sys_grp" and parts[2] == CurrentGroup and name ~= LP.Name then
            AddMessageToUI(GrpScroll, name, parts[3], Color3.fromRGB(150, 200, 255))
            local char = game.Players:FindFirstChild(name) and game.Players[name].Character
            if char then CreateCustomBubble(char, parts[3]) end

        elseif cmd == "/sys_msg" and name ~= LP.Name then
            AddMessageToUI(GenScroll, name, parts[2])
            local char = game.Players:FindFirstChild(name) and game.Players[name].Character
            if char then CreateCustomBubble(char, parts[2]) end
        end
    end
end

if Success and Socket then
