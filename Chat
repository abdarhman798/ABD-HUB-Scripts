local function FireServerMessage(cmd)
    if Success and Socket then
        local payload = {
            sender = LP.Name,
            content = cmd .. secretTag 
        }
        pcall(function()
            Socket:Send(HttpService:JSONEncode(payload))
        end)
    end
end

local function UpdateRadarUI()
    for _, v in pairs(UsersScroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for name, _ in pairs(ActiveUsers) do
        local b = Instance.new("TextButton", UsersScroll)
        b.Size = UDim2.new(1, 0, 0, 30); b.BackgroundColor3 = SelectedUsers[name] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 0, 0)
        b.TextColor3 = Color3.new(1,1,1); b.Font = SafeFont; b.TextSize = 14
        
        local statusText = PlayersInGroups[name] and " [مشغول]" or ""
        b.Text = "👤 " .. name .. statusText
        Instance.new("UICorner", b)
        
        b.MouseButton1Click:Connect(function()
            SelectedUsers[name] = not SelectedUsers[name]
            b.BackgroundColor3 = SelectedUsers[name] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 0, 0)
        end)
    end
end

