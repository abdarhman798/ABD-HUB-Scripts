local function FireServerMessage(cmd)
    if Success and Socket then
        local payload = { sender = LP.Name, content = cmd .. secretTag }
        pcall(function() Socket:Send(HttpService:JSONEncode(payload)) end)
    end
end

local function BroadcastGroupState()
    if GroupState.Owner == LP.Name then
        local json = HttpService:JSONEncode(GroupState)
        FireServerMessage("/sys_syncgrp|" .. json)
    end
end

local function UpdateGroupManageUI()
    if not GroupState.Active then
        SettingsCreateFrame.Visible = true
        GroupManageFrame.Visible = false
        return
    end
    SettingsCreateFrame.Visible = false
    GroupManageFrame.Visible = true

    local count = 0
    for _, v in pairs(GrpMembersScroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for memberName, _ in pairs(GroupState.Members) do
        count = count + 1
        local b = Instance.new("TextButton", GrpMembersScroll)
        b.Size = UDim2.new(1, 0, 0, 30); b.BackgroundColor3 = Color3.fromRGB(40, 0, 0); b.TextColor3 = Color3.new(1,1,1); b.Font = SafeFont; b.TextSize = 14
        Instance.new("UICorner", b)
        
        local role = ""
        if memberName == GroupState.Owner then role = " (👑 مالك)" elseif GroupState.Admins[memberName] then role = " (🛡️ مشرف)" end
        b.Text = "👤 " .. memberName .. role

        -- فتح واجهة الإدارة عند الضغط
        b.MouseButton1Click:Connect(function()
            if memberName == LP.Name then return end
            
            local iAmOwner = (GroupState.Owner == LP.Name)
            local iAmAdmin = GroupState.Admins[LP.Name]
            local targetIsOwner = (GroupState.Owner == memberName)
            local targetIsAdmin = GroupState.Admins[memberName]

            if iAmOwner or (iAmAdmin and not targetIsOwner and not targetIsAdmin) then
                TargetActionPlayer = memberName
                ActionTitle.Text = "إدارة: " .. memberName
                AdminToggleBtn.Visible = iAmOwner 
                ActionMenu.Visible = true
                MuteMenu.Visible = false
            end
        end)
    end
    GrpInfoLabel.Text = "المجموعة: " .. GroupState.Name .. " | الأعضاء: " .. count
end

